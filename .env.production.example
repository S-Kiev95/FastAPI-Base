# ============================================================================
# Production Environment Configuration
# ============================================================================
# Copiar a .env y configurar con valores reales
# ============================================================================

# Environment
ENVIRONMENT=production

# ============================================================================
# Database (PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql://user:CHANGE_ME@localhost:5432/seguros_db

# ============================================================================
# Redis (Cache & Rate Limiting)
# ============================================================================
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_SECURE_REDIS_PASSWORD
REDIS_DB=0
CACHE_TTL=300

# ============================================================================
# Security
# ============================================================================
# Generar con: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_256_BIT_SECRET_KEY_HERE

# Enforce strong passwords (TRUE en producción)
ENFORCE_STRONG_PASSWORDS=true

# Access & Refresh token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
INVITATION_EXPIRE_HOURS=48

# ============================================================================
# CORS Configuration
# ============================================================================
# Dominios permitidos (separados por coma, NO usar * en producción)
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH
CORS_HEADERS=*

# ============================================================================
# S3 Storage (AWS S3, MinIO, Backblaze B2)
# ============================================================================
USE_S3=true
S3_BUCKET_NAME=your-production-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME_AWS_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_AWS_SECRET_KEY
S3_ENDPOINT_URL=  # Dejar vacío para AWS S3, o especificar URL para MinIO/B2

# File size limits
MAX_FILE_SIZE=10485760  # 10MB

# ============================================================================
# SMTP Email Configuration
# ============================================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME_SENDGRID_API_KEY
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=YourApp
SMTP_USE_TLS=true
FRONTEND_URL=https://app.yourdomain.com

# ============================================================================
# Observability (Sentry Error Tracking)
# ============================================================================
SENTRY_DSN=https://YOUR_SENTRY_DSN@o123456.ingest.sentry.io/123456
SENTRY_TRACES_SAMPLE_RATE=0.1  # 10% de requests (ajustar según volumen)

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json o text
LOG_FILE=  # Opcional: /var/log/fastapi/app.log

# ============================================================================
# API Configuration
# ============================================================================
API_TITLE=SaaS Backend API
API_VERSION=1.0.0
API_DESCRIPTION=Production SaaS Backend with Multi-Tenancy

# ============================================================================
# Server Configuration
# ============================================================================
HOST=0.0.0.0
PORT=8000
RELOAD=false  # NO hot reload en producción

# ============================================================================
# Multi-Tenancy & SaaS Features
# ============================================================================
DEFAULT_PLAN=free
SYSTEM_ORG_SLUG=system
SYSTEM_ADMIN_EMAIL=admin@yourdomain.com
SYSTEM_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Feature Flags
SOFT_DELETE_ENABLED=true
AUDIT_LOG_ENABLED=true
API_KEYS_ENABLED=true
GDPR_EXPORT_ENABLED=true
ACCOUNT_DELETION_GRACE_DAYS=30

# API Key prefix
API_KEY_PREFIX=sk_live_

# ============================================================================
# Billing / Payment Gateways
# ============================================================================
# Opciones: stripe, mercadopago, polar
ACTIVE_PAYMENT_GATEWAY=stripe

# Stripe
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# MercadoPago (opcional)
# MERCADOPAGO_ACCESS_TOKEN=APP-CHANGE-ME
# MERCADOPAGO_WEBHOOK_SECRET=CHANGE_ME

# Polar (opcional)
# POLAR_ACCESS_TOKEN=polar_CHANGE_ME
# POLAR_WEBHOOK_SECRET=CHANGE_ME

# ============================================================================
# OAuth (opcional)
# ============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================================
# Email Templates
# ============================================================================
EMAIL_TEMPLATES_DIR=app/templates/emails
